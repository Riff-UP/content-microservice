# Application
PORT=3002
TCP_PORT=3003
CONTENT_MS_HOST=0.0.0.0

# MongoDB (runtime principal del microservicio)
DB_PORT=27018
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=content_db

# RabbitMQ
RABBITMQ_PORT=5673
RABBITMQ_MANAGEMENT_PORT=15673
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Cloudflare R2
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_BUCKET=your_bucket_name
R2_PUBLIC_URL=https://your-public-url.com

# Analytics PostgreSQL (DB separada de users-ms y del runtime Mongo)
ANALYTICS_DB_PORT=5435
ANALYTICS_DB_USER=content_analytics
ANALYTICS_DB_PASSWORD=content_analytics
ANALYTICS_DB_NAME=content_analytics
ANALYTICS_DB_URL=postgresql://content_analytics:content_analytics@localhost:5435/content_analytics
ANALYTICS_DB_SSL=false

# Analytics experiment config
ANALYTICS_PROJECT_ID=content-ms
ANALYTICS_PROJECT_ID_NUMERIC=1
ANALYTICS_PROJECT_TYPE=SOCIAL_NETWORK
ANALYTICS_DB_ENGINE=POSTGRESQL
ANALYTICS_DB_VERSION=16
ANALYTICS_INDEX_STRATEGY=BASELINE_INDEX
ANALYTICS_REGISTERED_EMAIL=
ANALYTICS_REGISTERED_DATE=
ANALYTICS_AUTO_RESET=false

# Google OAuth / BigQuery
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
ANALYTICS_CALLBACK_URL=http://localhost:3000/api/analytics/auth/google/callback
ANALYTICS_ACCESS_TOKEN=
BIGQUERY_PROJECT_ID=data-from-software
BIGQUERY_DATASET=benchmarking_warehouse
BIGQUERY_TABLE=daily_query_metrics
